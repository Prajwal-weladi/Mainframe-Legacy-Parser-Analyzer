    "B000-INITIALIZATION": {
      "section": "A000-MAIN-PROCESSING",
      "start_line": 54,
      "end_line": 63,
      "content": "    MOVE SPACES TO CUSTOMER-RECORD.\n    MOVE 0 TO SQL-CODE-VAL.\n    ACCEPT WS-SYS-DATE FROM DATE.\n    OPEN INPUT CUSTFILE.\n    IF VSAM-STATUS NOT = '00'\n        MOVE VSAM-STATUS TO VSAM-FEEDBACK\n        PERFORM G000-HANDLE-ERROR\n    END-IF.\n",
      "calls": [
        {
          "type": "PERFORM",
          "target": "G000-HANDLE-ERROR",
          "thru": null
        }
      ],
      "external_calls": [],
      "db2": [],
      "ims": [],
      "idms": [],
      "mq": [],
      "cics": [],
      "vsam": [],
      "moves": [
        {
          "source": "SPACES",
          "destination": "CUSTOMER-RECORD"
        },
        {
          "source": "0",
          "destination": "SQL-CODE-VAL"
        },
        {
          "source": "VSAM-STATUS",
          "destination": "VSAM-FEEDBACK"
        },
        {
          "source": "VSAM-STATUS",
          "destination": "PERFORM"
        },
        {
          "source": "VSAM-STATUS",
          "destination": "G000-HANDLE-ERROR"
        },
        {
          "source": "VSAM-STATUS",
          "destination": "END-IF"
        }
      ]
    },
    "C000-READ-CUSTOMER-DATA": {
      "section": "A000-MAIN-PROCESSING",
      "start_line": 64,
      "end_line": 89,
      "content": "    EXEC SQL\n        SELECT CUST_NAME, CUST_SSN, CUST_ACCOUNT_NUM\n        INTO :CUST-NAME, :CUST-SSN, :CUST-ACCOUNT-NUM\n        FROM DB2_CUST_TABLE\n        WHERE CUST_ID = :CUST-ID\n    END-EXEC.\n\n    CALL 'CBLTDLI' USING IMS-GU\n                         CUST-SEG-IO-AREA\n                         CUST-SEG-SSA.\n\n    OBTAIN FIRST CUST-RECORD-IDMS\n        WITHIN CUST-AREA-IDMS.\n\n    MOVE CUST-ID TO VSAM-CUST-KEY.\n    READ CUSTFILE\n        INVALID KEY\n            MOVE '10' TO VSAM-STATUS\n            PERFORM G000-HANDLE-ERROR\n    END-READ.\n",
      "calls": [
        {
          "type": "PERFORM",
          "target": "G000-HANDLE-ERROR",
          "thru": null
        }
      ],
      "external_calls": [],
      "db2": [
        {
          "command": "SELECT",
          "table": "DB2_CUST_TABLE",
          "raw_sql": "SELECT CUST_NAME, CUST_SSN, CUST_ACCOUNT_NUM\n        INTO :CUST-NAME, :CUST-SSN, :CUST-ACCOUNT-NUM\n        FROM DB2_CUST_TABLE\n        WHERE CUST_ID = :CUST-ID"
        }
      ],
      "ims": [
        {
          "function": "GU",
          "arguments": [
            "CUST-SEG-IO-AREA",
            "CUST-SEG-SSA"
          ]
        }
      ],
      "idms": [
        {
          "verb": "OBTAIN",
          "record": "CUST-RECORD-IDMS",
          "area": "CUST-AREA-IDMS"
        }
      ],
      "mq": [],
      "cics": [],
      "vsam": [
        {
          "operation": "READ",
          "file_variable": "CUSTFILE"
        }
      ],
      "moves": [
        {
          "source": "CUST-ID",
          "destination": "VSAM-CUST-KEY"
        }
      ]
    },
    "D000-PROCESS-PII-DATA": {
      "section": "A000-MAIN-PROCESSING",
      "start_line": 90,
      "end_line": 95,
      "content": "    MOVE CUST-SSN TO WS-PII-LOG-SSN.\n    MOVE CUST-ACCOUNT-NUM TO WS-MQ-MSG-BUFF(10:12).\n",
      "calls": [],
      "external_calls": [],
      "db2": [],
      "ims": [],
      "idms": [],
      "mq": [],
