        {
          "source": "CUST-ACCOUNT-NUM",
          "destination": "WS-MQ-MSG-BUFF"
        }
      ]
    },
    "E000-LOG-TO-MQ": {
      "section": "A000-MAIN-PROCESSING",
      "start_line": 96,
      "end_line": 107,
      "content": "    CALL 'MQPUT' USING MQ-HCONN\n                       MQ-HOBJ\n                       MQ-MD\n                       MQ-PMO\n                       WS-MQ-MSG-BUFF\n                       MQ-REASON-CODE.\n    IF MQ-REASON-CODE NOT = 0\n        PERFORM G000-HANDLE-ERROR\n    END-IF.\n",
      "calls": [
        {
          "type": "PERFORM",
          "target": "G000-HANDLE-ERROR",
          "thru": null
        }
      ],
      "external_calls": [],
      "db2": [],
