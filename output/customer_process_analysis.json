  "paragraphs": {
    "PROC-ENTRY": {
      "section": "A000-MAIN-PROCESSING",
      "start_line": 42,
      "end_line": 53,
      "content": "    PERFORM B000-INITIALIZATION.\n    PERFORM C000-READ-CUSTOMER-DATA.\n    IF SQL-CODE-VAL = 0\n        PERFORM D000-PROCESS-PII-DATA\n        PERFORM E000-LOG-TO-MQ\n        PERFORM F000-SEND-CICS-MAP\n    ELSE\n        PERFORM G000-HANDLE-ERROR\n    END-IF.\n    PERFORM H000-TERMINATION.\n    GOBACK.\n",
      "calls": [
        {
          "type": "PERFORM",
          "target": "B000-INITIALIZATION",
          "thru": null
        },
        {
          "type": "PERFORM",
          "target": "C000-READ-CUSTOMER-DATA",
          "thru": null
        },
        {
          "type": "PERFORM",
          "target": "D000-PROCESS-PII-DATA",
