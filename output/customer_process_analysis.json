      "start_line": 108,
      "end_line": 116,
      "content": "    EXEC CICS SEND\n        MAP('CUSTMAP')\n        MAPSET('CUSTSET')\n        FROM(CUSTOMER-RECORD)\n        ERASE\n    END-CICS.\n",
