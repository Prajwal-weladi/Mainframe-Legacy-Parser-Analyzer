       IDENTIFICATION DIVISION.
       PROGRAM-ID. CBACT02C.
       AUTHOR. TEST-AUTHOR.
       ENVIRONMENT DIVISION.
       INPUT-OUTPUT SECTION.
       FILE-CONTROL.
           SELECT CUSTOMER-FILE ASSIGN TO CUSTOMER.
       DATA DIVISION.
       FILE SECTION.
       FD  CUSTOMER-FILE.
       01  CUSTOMER-RECORD-RAW  PIC X(80).
       WORKING-STORAGE SECTION.
           COPY CVACT02Y.
       PROCEDURE DIVISION.
       0000-MAIN-PROCESSING.
           OPEN INPUT CUSTOMER-FILE.
           READ CUSTOMER-FILE INTO CUSTOMER-RECORD.
           PERFORM 1000-PROCESS-RECORD.
           CLOSE CUSTOMER-FILE.
           GOBACK.
       1000-PROCESS-RECORD.
           EXEC SQL
               SELECT FIRST_NAME, LAST_NAME
               INTO :WS-FIRST-NAME, :WS-LAST-NAME
               FROM DB2_CUSTOMER_TBL
               WHERE CUST_ID = :WS-CUST-ID
           END-EXEC.
           EXEC CICS SEND MAP('MAP1') MAPSET('CVACT02B') END-EXEC.
