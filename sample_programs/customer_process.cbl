003900 PROCEDURE DIVISION USING LK-INPUT-DATA.
004000
004100 A000-MAIN-PROCESSING SECTION.
004200     PERFORM B000-INITIALIZATION.
004300     PERFORM C000-READ-CUSTOMER-DATA.
004400     IF SQL-CODE-VAL = 0
004500         PERFORM D000-PROCESS-PII-DATA
004600         PERFORM E000-LOG-TO-MQ
004700         PERFORM F000-SEND-CICS-MAP
004800     ELSE
004900         PERFORM G000-HANDLE-ERROR
005000     END-IF.
005100     PERFORM H000-TERMINATION.
005200     GOBACK.
005300
005400 B000-INITIALIZATION.
005500     MOVE SPACES TO CUSTOMER-RECORD.
005600     MOVE 0 TO SQL-CODE-VAL.
005700     ACCEPT WS-SYS-DATE FROM DATE.
005800     OPEN INPUT CUSTFILE.
005900     IF VSAM-STATUS NOT = '00'
006000         MOVE VSAM-STATUS TO VSAM-FEEDBACK
006100         PERFORM G000-HANDLE-ERROR
006200     END-IF.
006300
006400 C000-READ-CUSTOMER-DATA.
006500      * READ FROM DB2 DATABASE
006600     EXEC SQL
006700         SELECT CUST_NAME, CUST_SSN, CUST_ACCOUNT_NUM
006800         INTO :CUST-NAME, :CUST-SSN, :CUST-ACCOUNT-NUM
006900         FROM DB2_CUST_TABLE
007000         WHERE CUST_ID = :CUST-ID
007100     END-EXEC.
007200
007300      * ALSO DEMONSTRATE IMS READ FOR RELATED SEGMENTS
007400     CALL 'CBLTDLI' USING IMS-GU
007500                          CUST-SEG-IO-AREA
007600                          CUST-SEG-SSA.
007700
007800      * ALSO DEMONSTRATE IDMS READ
007900     OBTAIN FIRST CUST-RECORD-IDMS
008000         WITHIN CUST-AREA-IDMS.
008100
008200      * DEMONSTRATE VSAM FILE READ
008300     MOVE CUST-ID TO VSAM-CUST-KEY.
008400     READ CUSTFILE
008500         INVALID KEY
008600             MOVE '10' TO VSAM-STATUS
008700             PERFORM G000-HANDLE-ERROR
008800     END-READ.
008900
009000 D000-PROCESS-PII-DATA.
009100      * LOG CUST-SSN WHICH IS A PII ELEMENT TO WS-PII-LOG-SSN
009200     MOVE CUST-SSN TO WS-PII-LOG-SSN.
009300      * MOVE ACCOUNT NUMBER AS WELL
009400     MOVE CUST-ACCOUNT-NUM TO WS-MQ-MSG-BUFF(10:12).
009500
009600 E000-LOG-TO-MQ.
009700      * DEMONSTRATE IBM MQ SEND
009800     CALL 'MQPUT' USING MQ-HCONN
009900                        MQ-HOBJ
010000                        MQ-MD
010100                        MQ-PMO
010200                        WS-MQ-MSG-BUFF
010300                        MQ-REASON-CODE.
010400     IF MQ-REASON-CODE NOT = 0
010500         PERFORM G000-HANDLE-ERROR
010600     END-IF.
010700
010800 F000-SEND-CICS-MAP.
010900      * DEMONSTRATE CICS TERMINAL INTERFACE
011000     EXEC CICS SEND
011100         MAP('CUSTMAP')
011200         MAPSET('CUSTSET')
011300         FROM(CUSTOMER-RECORD)
011400         ERASE
011500     END-CICS.
011600
011700 G000-HANDLE-ERROR.
011800     DISPLAY 'ERROR OCCURRED. SQL-CODE=' SQL-CODE-VAL
011900     DISPLAY 'VSAM-STATUS=' VSAM-STATUS
012000     MOVE 'AN ERROR WAS ENCOUNTERED IN PROCESSING' TO ERR-MSG.
012100
012200 H000-TERMINATION.
012300     CLOSE CUSTFILE.
012400
012500 X999-DEAD-PARAGRAPH.
012600      * THIS PARAGRAPH IS NEVER CALLED OR PERFORMED
012700     DISPLAY 'THIS IS DEAD CODE'
012800     MOVE 'DEAD' TO WS-MQ-MSG-BUFF.
